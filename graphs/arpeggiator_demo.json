{
  "nodes": {
    "clock1": { "type": "Clock", "params": { "bpm": 120.0 } },
    "cp1": { "type": "ChordProgression", "params": {
      "steps": 4,
      "key_root": 0, "mode": 0, "octave": 4,
      "beats_per_step": 4, "gate_length": 0.95, "velocity": 0.8,
      "degree_0": 0, "voicing_0": 0, "ext_0": 1,
      "degree_1": 3, "voicing_1": 0, "ext_1": 1,
      "degree_2": 4, "voicing_2": 0, "ext_2": 0,
      "degree_3": 0, "voicing_3": 1, "ext_3": 0
    }},
    "arp1": { "type": "Arpeggiator", "params": {
      "mode": 0, "octaves": 2, "rate": 3,
      "gate_length": 0.6, "swing": 0.0, "latch": false,
      "mod_steps": 4,
      "vel_0": 1.0, "vel_1": 0.5, "vel_2": 0.7, "vel_3": 0.4,
      "tr_0": 0, "tr_1": 0, "tr_2": 0, "tr_3": 0
    }},
    "synth1": { "type": "WavetableSynth", "params": {
      "wavetable": 1, "position": 0.4,
      "attack": 0.01, "decay": 0.15,
      "sustain": 0.3, "release": 0.2, "amplitude": 0.25,
      "filter_cutoff": 4000.0, "filter_resonance": 0.3
    }},
    "out1": { "type": "audio_out", "params": {} }
  },
  "connections": [
    { "from": "clock1/beat_phase", "to": "cp1/beat_phase" },
    { "from": "clock1/beat_phase", "to": "arp1/beat_phase" },
    { "from": "cp1/notes",      "to": "arp1/notes" },
    { "from": "cp1/velocities", "to": "arp1/velocities" },
    { "from": "cp1/gates",      "to": "arp1/gates" },
    { "from": "arp1/notes",      "to": "synth1/notes" },
    { "from": "arp1/velocities", "to": "synth1/velocities" },
    { "from": "arp1/gates",      "to": "synth1/gates" },
    { "from": "synth1/output_left",  "to": "out1/left" },
    { "from": "synth1/output_right", "to": "out1/right" }
  ]
}
