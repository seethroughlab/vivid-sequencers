{
  "nodes": {
    "clock1": { "type": "Clock", "params": { "bpm": 100.0 } },
    "cp1": { "type": "ChordProgression", "params": {
      "steps": 4,
      "key_root": 0, "mode": 0, "octave": 4,
      "beats_per_step": 4, "gate_length": 0.8, "velocity": 0.8,
      "degree_0": 1, "voicing_0": 1, "ext_0": 1,
      "degree_1": 4, "voicing_1": 0, "ext_1": 1,
      "degree_2": 0, "voicing_2": 0, "ext_2": 0,
      "degree_3": 5, "voicing_3": 0, "ext_3": 0
    }},
    "ps1": { "type": "WavetableSynth", "params": {
      "wavetable": 1, "position": 0.3,
      "attack": 0.15, "decay": 0.3,
      "sustain": 0.7, "release": 0.5, "amplitude": 0.25,
      "filter_cutoff": 6000.0, "filter_resonance": 0.2
    }},
    "out1": { "type": "audio_out", "params": {} }
  },
  "connections": [
    { "from": "clock1/beat_phase", "to": "cp1/beat_phase" },
    { "from": "cp1/notes",      "to": "ps1/notes" },
    { "from": "cp1/velocities", "to": "ps1/velocities" },
    { "from": "cp1/gates",      "to": "ps1/gates" },
    { "from": "ps1/output_left",  "to": "out1/left" },
    { "from": "ps1/output_right", "to": "out1/right" }
  ]
}
