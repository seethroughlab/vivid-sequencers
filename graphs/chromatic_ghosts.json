{
  "schema_version": 1,
  "vivid_version": "0.1.0",
  "meta": {
    "id": "chromatic_ghosts",
    "title": "Chromatic Ghosts",
    "description": "IDM glitch drone: three polyrhythmic Euclidean rhythms (5/8, 3/4, 7/16) drive a random-pitch lead, square bass, and stuttery pink noise through a resonant filter, bitcrusher, and dotted-8th delay at 140 BPM. Lo-fi blocky monochrome visuals with block displacement and aggressive beat-triggered glitch.",
    "tags": [
      "audio",
      "synthesis",
      "idm",
      "glitch",
      "euclidean",
      "polyrhythm",
      "demo"
    ],
    "difficulty": "intermediate",
    "domains": [
      "audio",
      "control",
      "gpu"
    ],
    "requires_packages": [
      "vivid-glitch"
    ],
    "featured_rank": 23
  },
  "nodes": {
    "clock": {
      "type": "Clock",
      "params": {
        "bpm": 140.0
      }
    },
    "euclid_lead": {
      "type": "Euclidean",
      "params": {
        "hits": 5,
        "steps": 8,
        "rotation": 0,
        "gate_length": 0.3,
        "rate": 3
      }
    },
    "euclid_bass": {
      "type": "Euclidean",
      "params": {
        "hits": 3,
        "steps": 8,
        "rotation": 3,
        "gate_length": 0.5,
        "rate": 2
      }
