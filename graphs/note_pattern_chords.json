{
  "meta": {
    "id": "note_pattern_chords",
    "title": "Note Pattern Chords",
    "description": "Four cycling chord types with varied root notes, driven by NotePattern into a wavetable synth. The thumbnail uses a 7-color palette for chord types — different roots give different bar heights, chord types give different colors.",
    "tags": ["chords", "note-pattern", "sequencer", "demo"],
    "difficulty": "beginner",
    "domains": ["audio"],
    "requires_packages": ["vivid-sequencers"]
  },
  "nodes": {
    "clock1": {
      "type": "Clock",
      "params": { "bpm": 100.0 }
    },
    "pattern1": {
      "type": "NotePattern",
      "params": {
        "steps": 4,
        "octave": 4,
        "beats_per_step": 4,
        "gate_length": 0.9,
        "velocity": 0.8,
        "root_0": 0, "type_0": 6,
        "root_1": 5, "type_1": 1,
        "root_2": 7, "type_2": 4,
        "root_3": 4, "type_3": 0
      }
    },
    "synth1": {
      "type": "WavetableSynth",
      "params": {
        "wavetable": 1,
        "position": 0.5,
        "attack": 0.02,
        "decay": 0.3,
        "sustain": 0.6,
        "release": 0.4,
        "amplitude": 0.25,
        "filter_cutoff": 3500.0,
        "filter_resonance": 0.15
      }
    },
    "out1": { "type": "audio_out", "params": {} }
  },
  "connections": [
    { "from": "clock1/beat_phase", "to": "pattern1/beat_phase" },
    { "from": "pattern1/notes",      "to": "synth1/notes" },
    { "from": "pattern1/velocities", "to": "synth1/velocities" },
    { "from": "pattern1/gates",      "to": "synth1/gates" },
    { "from": "synth1/output",       "to": "out1/input" }
  ]
}
