{
  "meta": {
    "title": "Tracker Demo",
    "description": "Four-chord progression (C-Am-F-G) with arpeggiated melody and bass, driven by the Tracker sequencer into a wavetable synth.",
    "tags": ["tracker", "sequencer", "wavetable", "melody"],
    "difficulty": "intermediate",
    "domains": ["audio"],
    "packages": ["vivid-sequencers", "vivid-wavetable"]
  },
  "nodes": {
    "clock1": { "type": "Clock", "params": { "bpm": 120.0 } },
    "tracker1": { "type": "Tracker", "params": {
      "rate": 4,
      "speed": 6,
      "base_channel": 1,
      "channel_mode": 0,
      "pattern_data": ""
    }},
    "synth1": { "type": "WavetableSynth", "params": {
      "wavetable": 1,
      "position": 0.3,
      "amplitude": 0.25,
      "attack": 0.01,
      "decay": 0.3,
      "sustain": 0.6,
      "release": 0.4,
      "filter_type": 1,
      "filter_cutoff": 3000.0,
      "filter_resonance": 0.2,
      "filter_env_amount": 0.4,
      "filter_attack": 0.01,
      "filter_decay": 0.4,
      "filter_sustain": 0.2,
      "filter_release": 0.3,
      "stereo_spread": 0.6,
      "unison_voices": 3,
      "unison_spread": 15.0,
      "unison_stereo": 0.8
    }},
    "aout": { "type": "audio_out", "params": {} }
  },
  "connections": [
    { "from": "clock1/beat_phase", "to": "tracker1/beat_phase" },
    { "from": "tracker1/notes",      "to": "synth1/notes" },
    { "from": "tracker1/velocities", "to": "synth1/velocities" },
    { "from": "tracker1/gates",      "to": "synth1/gates" },
    { "from": "synth1/output",       "to": "aout/input" }
  ]
}
